# FiveServ — environment variables (Vite uses VITE_ prefix to expose to client)
# Copy this file to .env (or .env.local) and replace placeholder values.

VITE_PHONE=[PHONE_NUMBER]
VITE_DOMAIN=fiveserv.net
VITE_EMAIL=info@fiveserv.net
VITE_COMPANY_NAME=FiveServ Property Solutions
VITE_COMPANY_LEGAL=FiveServ Property Solutions LLC
VITE_BASE_CITY=Orlando
VITE_BASE_STATE=FL

# Tracking
VITE_GA4_ID=[GA4_MEASUREMENT_ID]
VITE_GSC_CODE=[GOOGLE_SEARCH_CONSOLE_CODE]
VITE_CLARITY_CODE=[MICROSOFT_CLARITY_CODE]

# GHL (GoHighLevel)
# VITE_FORM_GHL=[GHL_FORM_EMBED_URL]
# VITE_GHL_CHAT=[GHL_CHAT_WIDGET_SNIPPET]

# Live stats — update monthly with the actual count of completed units this month.
# Read by src/components/fiveserv/LiveStatsBar.tsx. Defaults to 0 when unset.
VITE_UNITS_THIS_MONTH=0
